# ── AI rehber (optional) ────────────────────────────────────────────
# The AI guide lens degrades gracefully when no key is present: search +
# retrieval still work; only the generated synthesis is disabled.
#
# Provider is configurable. Leave blank to ship without AI.
# Default provider is Groq's OpenAI-compatible endpoint (free tier).
#
#   1. Get a key at https://console.groq.com  (or any OpenAI-compatible host)
#   2. Copy this file to .env and fill the value
#   3. Never commit .env

VITE_LLM_KEY=
# Override the endpoint/model to use a different OpenAI-compatible provider:
VITE_LLM_URL=https://api.groq.com/openai/v1/chat/completions
VITE_LLM_MODEL=llama-3.3-70b-versatile
